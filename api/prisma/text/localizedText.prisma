model LocalizedText {
  id       Int    @id @default(autoincrement())
  content  String
  language Lang   @default(EN)

  translatedTextId Int
  translatedText   TranslatedText @relation(fields: [translatedTextId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([translatedTextId, language])
}
