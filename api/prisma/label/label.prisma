model Label {
  id Int @id @default(autoincrement())

  contentId Int
  content   TranslatedText @relation("LabelContent", fields: [contentId], references: [id])

  color      String

  definitionId Int
  definition   TranslatedText @relation("LabelDefinition", fields: [definitionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  highlights HighlightLabel[]
  posts PostLabel[]
}
